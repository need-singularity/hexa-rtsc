// ─── main ───

fn main() {
    let _raw = args()
    let mut _sidx = -1
    let mut _i = 0
    while _i < _raw.len() {
        if _raw[_i].ends_with(".hexa") { _sidx = _i; break }
        _i = _i + 1
    }
    let mut _user_start = 2
    if _sidx >= 0 { _user_start = _sidx + 1 }

    let mut a: [str] = ["hexa_rtsc_cli", "hexa_rtsc_router"]
    let mut _ua = _user_start
    while _ua < _raw.len() {
        a = a + [_raw[_ua]]
        _ua = _ua + 1
    }
    let n = len(a)

    if n < 3 {
        cmd_help()
        return
    }

    let sub = a[2]

    if sub == "--version" || sub == "-V" || sub == "version" {
        cmd_version()
        return
    }

    if sub == "help" || sub == "--help" || sub == "-h" { cmd_help(); return }

    if sub == "status" {
        cmd_status(a)
    } else if sub == "rtsc" {
        cmd_rtsc(a)
    } else if sub == "sc" {
        cmd_sc(a)
    } else if sub == "selftest" {
        cmd_selftest(a)
    } else if sub == "lattice" {
        cmd_lattice(a)
    } else if sub == "verify" {
        cmd_verify(a)
    } else {
        eprintln("hexa-rtsc: unknown subcommand '" + sub + "'")
        eprintln("run 'hexa-rtsc help' for usage")
        _audit(sub, "", 2)
        exit(2)
    }
}
