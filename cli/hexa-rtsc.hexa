#!hexa strict
// hexa-rtsc/cli/hexa-rtsc.hexa — standalone hexa-rtsc CLI router (PLACEHOLDER)
//
// 2-verb Room-Temp Superconductor substrate router:
//   rtsc        — room-temp superconductor spec + falsifier preregister  [SPEC]
//   sc          — superconductor (BCS / Abrikosov) spec + n=6 lattice    [SPEC]
//
// Plus utility subcmds:
//   status      — verb status table (0/2 wired, 2/2 spec)
//   selftest    — verify sentinels present (placeholder dispatcher)
//   help        — this help
//   --version   — print version
//
// HONEST STATUS (raw#10 C3):
//   RT-SC is academically UNPROVEN as of 2026-05. LK-99 (2023) and
//   subsequent candidates have not been independently replicated.
//   This v1.0.0 CLI dispatcher is a PLACEHOLDER — no working empirical
//   sandbox; verbs print spec excerpt + falsifier preregister only.
//
// Constraints:
//   raw#9   — hexa-only orchestration; no python bridge
//   raw#15  — write-confined (audit log only)
//   raw#10  — honest C3 caveats embedded
//
// Cost: $0 (Mac local; pure spec-print, no compute).

let VERSION = "1.0.0"

// ─── env / path resolve ───

let HOME = env("HOME")
let HEXA_RTSC_ROOT_ENV = env("HEXA_RTSC_ROOT")

fn hexa_rtsc_root() -> str {
    if HEXA_RTSC_ROOT_ENV.len() > 0 { return HEXA_RTSC_ROOT_ENV }
    let inferred = exec("dirname \"$(dirname \"$0\")\" 2>/dev/null || true").trim()
    if inferred.len() > 0 { return inferred }
    return HOME + "/.hexa-rtsc"  // @allow-devpath
}

let HR = hexa_rtsc_root()

let SPEC_RTSC = HR + "/rtsc/room-temp-sc.md"
let SPEC_SC   = HR + "/sc/superconductor.md"

let LOG_PATH = HR + "/state/hexa_rtsc_cli.log"

// ─── arg helpers ───

fn shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn has_flag(a: [str], flag: str) -> bool {
    for x in a {
        if x == flag { return true }
    }
    return false
}

fn json_mode(a: [str]) -> bool {
    return has_flag(a, "--json")
}

// ─── audit log (jsonl) ───

fn _ts_now() -> str {
    return exec("date -u '+%Y-%m-%dT%H:%M:%SZ'").trim()
}

fn _audit(subcmd: str, args_str: str, exit_code: int) {
    let line = "{\"ts\":\"" + _ts_now() + "\",\"caller\":\"hexa_rtsc_standalone\",\"subcmd\":\"hexa-rtsc " +
               subcmd + "\",\"args\":\"" + args_str.replace("\"", "\\\"") +
               "\",\"exit_code\":" + str(exit_code) + ",\"version\":\"" + VERSION + "\"}"
    exec("mkdir -p " + shq(HR + "/state") + " 2>/dev/null")
    exec("echo " + shq(line) + " >> " + shq(LOG_PATH) + " 2>/dev/null")
}

fn _file_exists(p: str) -> bool {
    let r = exec("[ -f " + shq(p) + " ] && echo yes || echo no").trim()
    return r == "yes"
}

// ─── caveat printer (raw#10 honest C3) ───

fn _print_caveats() {
    println("")
    println("--- caveats (raw#10 C3) ---")
    println("  1. RT-SC is academically UNPROVEN (LK-99 etc. unsettled). v1.0.0 ships")
    println("     spec + falsifier preregister only — no working empirical sandbox.")
    println("  2. CLI dispatcher is PLACEHOLDER TBD; verbs print spec excerpt only.")
    println("  3. n=6 invariant lattice (σ·τ=48T Hc2, φ=2 Cooper pair, Tc=300K) is a")
    println("     CLOSED-FORM CANDIDATE, not empirical fit. Synthesis-side validation")
    println("     is out-of-repo (would require materials lab).")
    println("  4. Substrate-of-substrates: hexa-fusion (48T coil), hexa-ufo (Meissner),")
    println("     hexa-cern (SC magnet) all depend on this base. Their working")
    println("     status is upper-bounded by RT-SC empirical realisation.")
}

