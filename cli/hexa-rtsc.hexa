    if json_mode(a) {
        let mut js = "{\"hexa_rtsc\":\"" + VERSION + "\",\"subcmd\":\"status\","
        js = js + "\"verbs_total\":2,\"verbs_wired\":0,\"verbs_stub\":2,"
        js = js + "\"verdict\":\"SPEC_ONLY\","
        js = js + "\"verbs\":[\"rtsc:spec\",\"sc:spec\"],"
        js = js + "\"academic_status\":\"unproven\","
        js = js + "\"role\":\"substrate-of-substrates\""
        js = js + "}"
        println(js)
        return
    }

    println("hexa-rtsc " + VERSION + " status — Room-Temp Superconductor substrate-of-substrates")
    println("")
    println("  verb   status        n=6 lattice candidate         empirical")
    println("  ----   -----------   ---------------------------   --------------")
    println("  rtsc   SPEC v1.0.0   Tc=300K, σ·τ=48T, φ=2         UNPROVEN (TBD)")
    println("  sc     SPEC v1.0.0   Cooper φ=2, Abrikosov CN=6    UNPROVEN (TBD)")
    println("")
    println("  verdict: SPEC_ONLY (0/2 verbs wired; 2/2 spec + falsifier preregister)")
    println("")
    println("  substrate-of-substrates downstream consumers:")
    println("    need-singularity/hexa-fusion    (48T SC coil dep)")
    println("    need-singularity/hexa-ufo       (Stage-1 Meissner levitation dep)")
    println("    need-singularity/hexa-cern    (SC magnet dep)")
    println("")
    println("  drill into a verb:")
    println("    hexa-rtsc rtsc       (prints spec excerpt + falsifier table)")
    println("    hexa-rtsc sc         (prints spec excerpt + falsifier table)")
    println("    hexa-rtsc selftest   (placeholder sentinel sweep)")
    _print_caveats()
}

