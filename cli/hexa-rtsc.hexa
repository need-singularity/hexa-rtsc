// ─── subcommand: lattice ───
//
// Print n=6 closed-form lattice math live (sigma / tau / phi / Hc2 derived
// from divisor-function arithmetic, not memorized constants). Sister of
// hexa-sscb spec.md §7 — the lattice is the *correctness machinery*.

fn _div_sum(n: int) -> int {
    let mut s = 0
    let mut k = 1
    while k <= n {
        if n % k == 0 { s = s + k }
        k = k + 1
    }
    return s
}

fn _div_count(n: int) -> int {
    let mut c = 0
    let mut k = 1
    while k <= n {
        if n % k == 0 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn _gcd(a: int, b: int) -> int {
    let mut x = a
    let mut y = b
    while y != 0 {
        let t = x % y
        x = y
        y = t
    }
    return x
}

fn _phi(n: int) -> int {
    let mut c = 0
    let mut k = 1
    while k <= n {
        if _gcd(k, n) == 1 { c = c + 1 }
        k = k + 1
    }
    return c
}

fn cmd_lattice(a: [str]) {
    let n = 6
    let s = _div_sum(n)
    let t = _div_count(n)
    let p = _phi(n)
    let hc2 = s * t
    let lhs = s * p
    let rhs = n * t

    if json_mode(a) {
        let mut js = "{\"hexa_rtsc\":\"" + VERSION + "\",\"subcmd\":\"lattice\","
        js = js + "\"n\":" + str(n) + ","
        js = js + "\"sigma\":" + str(s) + ","
        js = js + "\"tau\":" + str(t) + ","
        js = js + "\"phi\":" + str(p) + ","
        js = js + "\"Hc2_T\":" + str(hc2) + ","
        js = js + "\"master\":" + str(lhs) + ","
        js = js + "\"holds\":" + (if lhs == rhs && lhs == 24 { "true" } else { "false" })
        js = js + "}"
        println(js)
        return
    }

    println("hexa-rtsc lattice — n=6 closed-form candidate (live computation)")
    println("")
    println("  σ(6) = " + str(s) + "    (divisor sum 1+2+3+6 = 12; BCS molecule)")
    println("  τ(6) = " + str(t) + "    (divisor count {1,2,3,6}; 4-phase ladder)")
    println("  φ(6) = " + str(p) + "    (Euler totient — coprime {1,5}; Cooper pair)")
    println("")
    println("  master identity:   σ·φ = " + str(lhs) + "  ?=  n·τ = " + str(rhs))
    if lhs == rhs && lhs == 24 {
        println("                     ✓ holds (J₂ = 24, Mathieu M₂₄)")
    } else {
        println("                     ✗ BROKEN — own 1 violation")
    }
    println("")
    println("  derived:           Hc2 = σ·τ = " + str(hc2) + " T  (critical magnetic field gate)")
    println("                     1/(σ-φ) = 1/" + str(s - p) + "  (SC magnet shrink ratio)")
    println("")
    println("  CLOSED-FORM CANDIDATE — empirical RT-SC unproven.")
    _audit("lattice", "", 0)
}

// ─── subcommand: verify ───
//
// Runs verify/*.hexa scripts in sequence (lattice / cross-doc / falsifier).
// Sister of hexa-sscb's `python3 verify/sscb_verify.py` + cross_doc_audit
// + bom_lattice trio.

fn _verify_one(name: str, path: str) -> int {
    println("")
    println("---- " + name + " (" + path + ") ----")
    let rc_str = exec("hexa run " + path + "; echo __RC=$?").trim()
    // Find the trailing __RC=N marker
    let lines = rc_str.split("\n")
    let last = lines[lines.len() - 1]
    let mut rc = 0
    if last.starts_with("__RC=") {
        let raw = last.replace("__RC=", "")
        rc = int(raw)
        let mut i = 0
        while i < lines.len() - 1 {
            println(lines[i])
            i = i + 1
        }
    } else {
        println(rc_str)
    }
    return rc
}

fn cmd_verify(a: [str]) {
    let scripts: [str] = [
        "verify/lattice_check.hexa",
        "verify/cross_doc_audit.hexa",
        "verify/calc_bcs.hexa",
        "verify/falsifier_check.hexa",
    ]
    let names: [str] = ["lattice", "cross-doc", "calc-bcs", "falsifier"]
    let mut passed = 0
    let mut failed = 0
    let mut i = 0
    println("hexa-rtsc verify — running " + str(scripts.len()) + " invariant audits")
    while i < scripts.len() {
        let path = HR + "/" + scripts[i]
        let rc = _verify_one(names[i], path)
        if rc == 0 { passed = passed + 1 }
        else       { failed = failed + 1 }
        i = i + 1
    }
    println("")
    println("========================================================================")
    let total = passed + failed
    println("  " + str(passed) + "/" + str(total) + " verify scripts passed")
    if json_mode(a) {
        let verdict = if failed == 0 { "PASS" } else { "FAIL" }
        let mut js = "{\"hexa_rtsc\":\"" + VERSION + "\",\"subcmd\":\"verify\","
        js = js + "\"passed\":" + str(passed) + ","
        js = js + "\"failed\":" + str(failed) + ","
        js = js + "\"verdict\":\"" + verdict + "\"}"
        println(js)
    }
    if failed == 0 {
        println("  __HEXA_RTSC_VERIFY__ PASS  (n=6 lattice + cross-doc + falsifier monotone)")
    } else {
        println("  __HEXA_RTSC_VERIFY__ FAIL  (" + str(failed) + " script(s) failed)")
    }
    _audit("verify", "", if failed == 0 { 0 } else { 1 })
    if failed > 0 { exit(1) }
}

// ─── subcommand: selftest ───

fn cmd_selftest(a: [str]) {
    let ok_rtsc = _file_exists(SPEC_RTSC)
    let ok_sc   = _file_exists(SPEC_SC)
    let ok_own  = _file_exists(HR + "/.own")
    let ok_ai   = _file_exists(HR + "/README.ai.md")
    let ok_v1   = _file_exists(HR + "/verify/lattice_check.hexa")
    let ok_v2   = _file_exists(HR + "/verify/cross_doc_audit.hexa")
    let ok_v3   = _file_exists(HR + "/verify/falsifier_check.hexa")
    let ok_lin  = _file_exists(HR + "/doc/lineage/origin.md")

    println("hexa-rtsc selftest — sentinel sweep (specs + own_v1 pattern + verify/)")
    println("")
    if ok_rtsc { println("  [OK]  rtsc spec    : " + SPEC_RTSC) }
    else       { println("  [!!]  rtsc spec    : MISSING " + SPEC_RTSC) }
    if ok_sc   { println("  [OK]  sc   spec    : " + SPEC_SC) }
    else       { println("  [!!]  sc   spec    : MISSING " + SPEC_SC) }
    if ok_own  { println("  [OK]  .own own_v1  : " + HR + "/.own") }
    else       { println("  [!!]  .own own_v1  : MISSING " + HR + "/.own") }
    if ok_ai   { println("  [OK]  README.ai.md : " + HR + "/README.ai.md") }
    else       { println("  [!!]  README.ai.md : MISSING") }
    if ok_v1   { println("  [OK]  verify/lattice_check.hexa") }
    else       { println("  [!!]  verify/lattice_check.hexa MISSING") }
    if ok_v2   { println("  [OK]  verify/cross_doc_audit.hexa") }
    else       { println("  [!!]  verify/cross_doc_audit.hexa MISSING") }
    if ok_v3   { println("  [OK]  verify/falsifier_check.hexa") }
    else       { println("  [!!]  verify/falsifier_check.hexa MISSING") }
    if ok_lin  { println("  [OK]  doc/lineage/origin.md") }
    else       { println("  [!!]  doc/lineage/origin.md MISSING") }

    let pass = ok_rtsc && ok_sc && ok_own && ok_ai && ok_v1 && ok_v2 && ok_v3 && ok_lin
    println("")
    if pass {
        println("__HEXA_RTSC_SELFTEST__ PASS  (sentinel only — empirical RT-SC unproven)")
    } else {
        println("__HEXA_RTSC_SELFTEST__ FAIL  (set HEXA_RTSC_ROOT or run from repo root)")
    }
    if json_mode(a) {
        println("{\"hexa_rtsc\":\"" + VERSION + "\",\"subcmd\":\"selftest\",\"verdict\":\"" + (if pass { "PASS" } else { "FAIL" }) + "\"}")
    }
    _print_caveats()
    _audit("selftest", "", if pass { 0 } else { 1 })
    if pass == false { exit(1) }
}

