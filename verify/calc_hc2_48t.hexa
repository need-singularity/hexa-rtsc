    println("  hexa.toml substrate_role anchor:")
    check_hexatoml_substrate_role()

    println("")
    println("  FALSIFIERS (" + str(FALSIFIERS.len()) + "):")
    for f in FALSIFIERS { println("    ✗ " + f) }

    println("========================================================================")
    let pass_n = RUN - FAIL
    println("  " + str(pass_n) + "/" + str(RUN) + " checks passed")
    if FAIL > 0 {
        println("__HEXA_RTSC_CALC_HC2_48T__ FAIL")
        exit(1)
    }
    println("  T1 algebraic locked: F-RTSC-3 Hc2=48T 3-sister bridge closed-form written.")
    println("  Empirical 48 T sustained SC coil at RT-SC ambient remains UNVERIFIED.")
    println("__HEXA_RTSC_CALC_HC2_48T__ PASS")
    exit(0)
}
