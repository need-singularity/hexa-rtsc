#!hexa strict
// tests/test_verify.hexa — exercise verify/run_all.hexa (8 invariant audits).
//
// Pass criterion: "8/8 scripts passed" from verify/run_all.hexa
//   (lattice + cross_doc + 4×calc_* + numerics_bcs + falsifier).
// F-SC-{1,2,3} at 67% (T1+T2); F-RTSC-{1,2,3} at 33% (T1 only).
// Run:
//     hexa run tests/test_verify.hexa
//
// Authority: own 1 (lattice), own 2 (falsifier), own 3 (code-scope).

fn main() {
    let root = env("HEXA_RTSC_ROOT")
    let mut p = "verify/run_all.hexa"
    if root.len() > 0 { p = root + "/verify/run_all.hexa" }

    let raw = exec("hexa run " + p + " 2>&1")
    if raw.contains("10/10 scripts passed") {
        println("test_verify: PASS  (verify/run_all.hexa 10/10)")
        return
    }
    println("test_verify: FAIL")
    println(raw.trim())
    exit(1)
}
