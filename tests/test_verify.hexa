#!hexa strict
// tests/test_verify.hexa — exercise verify/run_all.hexa (5 invariant audits).
//
// Pass criterion: "5/5 scripts passed" from verify/run_all.hexa
//   (lattice_check + cross_doc_audit + calc_bcs + calc_mcmillan + falsifier_check).
// Run:
//     hexa run tests/test_verify.hexa
//
// Authority: own 1 (lattice), own 2 (falsifier), own 3 (code-scope).

fn main() {
    let root = env("HEXA_RTSC_ROOT")
    let mut p = "verify/run_all.hexa"
    if root.len() > 0 { p = root + "/verify/run_all.hexa" }

    let raw = exec("hexa run " + p + " 2>&1")
    if raw.contains("5/5 scripts passed") {
        println("test_verify: PASS  (verify/run_all.hexa 5/5)")
        return
    }
    println("test_verify: FAIL")
    println(raw.trim())
    exit(1)
}
