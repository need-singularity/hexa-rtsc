#!hexa strict
// tests/test_verify.hexa — exercise verify/run_all.hexa (7 invariant audits).
//
// Pass criterion: "7/7 scripts passed" from verify/run_all.hexa
//   (lattice + cross_doc + calc_{bcs,mcmillan,hc2_48t,lk99} + falsifier).
// All 6 falsifiers now T1-anchored (33% closure each).
// Run:
//     hexa run tests/test_verify.hexa
//
// Authority: own 1 (lattice), own 2 (falsifier), own 3 (code-scope).

fn main() {
    let root = env("HEXA_RTSC_ROOT")
    let mut p = "verify/run_all.hexa"
    if root.len() > 0 { p = root + "/verify/run_all.hexa" }

    let raw = exec("hexa run " + p + " 2>&1")
    if raw.contains("7/7 scripts passed") {
        println("test_verify: PASS  (verify/run_all.hexa 7/7)")
        return
    }
    println("test_verify: FAIL")
    println(raw.trim())
    exit(1)
}
